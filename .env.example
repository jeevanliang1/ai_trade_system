# Local-only AI provider settings.
# Copy to .env.local and fill real secrets there. Do not commit .env.local.

AI_TRADE_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional command that lets this system ask OpenClaw for external research.
# It receives JSON on stdin: {"prompt": "...", "context": {...}}
AI_TRADE_OPENCLAW_RESEARCH_COMMAND=python scripts/openclaw_external_research.py

# Optional command that lets this system ask OpenClaw to deliver finished Agent results.
# It receives JSON on stdin: {"message": "...", "task": {...}}
AI_TRADE_OPENCLAW_NOTIFY_COMMAND=python scripts/openclaw_notify_user.py
